            "program": "${workspaceFolder}/bin/linux/debug/appweeb",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "preLaunchTask": "Build Linux Debug"
        },
        {
            "name": "Linux Release",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/linux/release/appweeb",
