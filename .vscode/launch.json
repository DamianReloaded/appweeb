        {
            "name": "Windows Release",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/windows/release/appweeb.exe",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "preLaunchTask": "Build Windows Release"
